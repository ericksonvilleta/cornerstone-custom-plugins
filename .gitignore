# ==========================================
# 1. OS JUNK EXCLUSIONS
# ==========================================
# macOS Finder files
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows thumbnail databases
Thumbs.db
ehthumbs.db
Desktop.ini

# ==========================================
# 2. CODE EDITOR & IDE CONFIGURATIONS
# ==========================================
# VS Code
.vscode/
*.code-workspace

# PhpStorm / JetBrains
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ==========================================
# 3. BUILD TOOLS & NODE DEPENDENCIES
# ==========================================
# If you use Webpack, Mix, or Gulp for compiling Elementor widget assets
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# Compiled assets map files (optional, but keeps diffs clean)
*.css.map
*.js.map

# ==========================================
# 4. SECURITY, SENSITIVE DATA & CREDENTIALS
# ==========================================
# Backup files, environment configs, and secret logs
*.env
*.log
*.sql
*.zip
*.tar.gz
wp-config-local.php

# ==========================================
# 5. WORDPRESS & ACF EXCLUSIONS
# ==========================================
# Ignore local ACF license configurations if saved in a file
acf-license.php
